# dotai — AI Connector Pack
# Copy this file to `.env` and fill in your personal tokens.
# `.env` is gitignored — never commit your real tokens.

# ─── GitHub ──────────────────────────────────────────────────────────────
# Create a Personal Access Token (classic or fine-grained) at:
#   https://github.com/settings/tokens
# Minimum scopes:
#   - repo (read/write code, issues, PRs)
#   - read:org (read org membership)
#   - workflow (if you want CI access)
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_replace_me

# ─── Atlassian (Jira + Confluence Cloud) ─────────────────────────────────
# Create an API token at:
#   https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_URL and CONFLUENCE_URL are usually the same site root
# (e.g., https://your-company.atlassian.net)

JIRA_URL=https://your-company.atlassian.net
JIRA_USERNAME=you@your-company.com
JIRA_API_TOKEN=replace_me

CONFLUENCE_URL=https://your-company.atlassian.net/wiki
CONFLUENCE_USERNAME=you@your-company.com
CONFLUENCE_API_TOKEN=replace_me

# ─── Optional: scope filters ─────────────────────────────────────────────
# Restrict which Jira projects / Confluence spaces the MCP server can touch.
# Comma-separated keys. Leave blank to allow all you have access to.
JIRA_PROJECTS_FILTER=
CONFLUENCE_SPACES_FILTER=
